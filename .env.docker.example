# Database (connects to the Docker Compose postgres service)
DATABASE_URL="postgresql://postgres:postgres@db:5432/characterforge"
DIRECT_URL="postgresql://postgres:postgres@db:5432/characterforge"

# Supabase Auth (required — get from supabase.com/dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# AI Generation (set MOCK_AI=true to skip real API calls)
REPLICATE_API_TOKEN=""
REPLICATE_MODEL="stability-ai/sdxl"
IMAGE_PROVIDER="huggingface"
HUGGINGFACE_API_KEY=""
MOCK_AI="true"

# Cloudflare R2 Storage (leave empty for mock/in-memory storage)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="characterforge-images"

# Upstash Redis (optional — for serverless rate limiting persistence)
# Falls back to in-memory rate limiting if not set
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
ALLOWED_ORIGIN="http://localhost:3000"
NODE_ENV="production"

# Payment (leave empty for mock mode)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_POPULAR=""
STRIPE_PRICE_PRO=""
