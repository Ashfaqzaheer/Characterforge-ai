# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/characterforge?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/characterforge"

# CORS — set to your application domain in production
ALLOWED_ORIGIN="http://localhost:3000"

# App URL — used as CORS fallback in dev and for Open Graph URL resolution
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Supabase Auth (get from supabase.com/dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# AI Generation
REPLICATE_API_TOKEN="your-replicate-api-token"
REPLICATE_MODEL="stability-ai/sdxl"
MOCK_AI="true"

# Image Provider: huggingface | replicate | mock
IMAGE_PROVIDER="huggingface"
HUGGINGFACE_API_KEY="your-huggingface-api-key"

# Cloudflare R2 (leave empty for in-memory mock storage)
R2_ACCOUNT_ID="your-r2-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="characterforge-images"

# Upstash Redis (optional — for serverless rate limiting persistence)
# Falls back to in-memory rate limiting if not set
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
