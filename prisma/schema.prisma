generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(uuid())
  supabaseId    String   @unique @map("supabase_id")
  email         String   @unique
  creditBalance    Int      @default(10) @map("credit_balance")
  stripeCustomerId String?  @unique @map("stripe_customer_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  characters    Character[]
  generations   Generation[]
  transactions  CreditTransaction[]
  purchases     PurchaseRecord[]

  @@map("users")
}

model Character {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  name            String   @db.VarChar(100)
  description     String   @db.VarChar(1000)
  age             String?  @db.VarChar(50)
  gender          String?  @db.VarChar(50)
  style           String?  @db.VarChar(200)
  outfit          String?  @db.VarChar(500)
  personality     String?  @db.VarChar(500)
  negativePrompt  String?  @map("negative_prompt") @db.VarChar(500)
  hairDescription String?  @map("hair_description") @db.VarChar(200)
  faceDescription String?  @map("face_description") @db.VarChar(200)
  eyeColor        String?  @map("eye_color") @db.VarChar(50)
  bodyType        String?  @map("body_type") @db.VarChar(100)
  colorPalette    String?  @map("color_palette") @db.VarChar(200)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  images      ReferenceImage[]
  generations Generation[]

  @@index([userId])
  @@map("characters")
}

model ReferenceImage {
  id           String   @id @default(uuid())
  characterId  String   @map("character_id")
  storageKey   String   @map("storage_key")
  filename     String
  mimeType     String   @map("mime_type")
  sizeBytes    Int      @map("size_bytes")
  width        Int
  height       Int
  uploadedAt   DateTime @default(now()) @map("uploaded_at")

  character    Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId])
  @@map("reference_images")
}

model Generation {
  id           String           @id @default(uuid())
  userId       String           @map("user_id")
  characterId  String           @map("character_id")
  prompt       String           @db.Text
  status       GenerationStatus @default(PENDING)
  imageKey     String?          @map("image_key")
  aspectRatio  String?          @map("aspect_ratio") @db.VarChar(10)
  errorMessage String?          @map("error_message")
  createdAt    DateTime         @default(now()) @map("created_at")
  completedAt  DateTime?        @map("completed_at")

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  character    Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  transactions CreditTransaction[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([characterId])
  @@map("generations")
}

enum GenerationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model CreditTransaction {
  id           String          @id @default(uuid())
  userId       String          @map("user_id")
  generationId String?         @map("generation_id")
  amount       Int
  type         TransactionType
  createdAt    DateTime        @default(now()) @map("created_at")

  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  generation   Generation? @relation(fields: [generationId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@map("credit_transactions")
}

model PurchaseRecord {
  id                    String   @id @default(uuid())
  userId                String   @map("user_id")
  packId                String   @map("pack_id")
  stripePaymentIntentId String   @unique @map("stripe_payment_intent_id")
  creditsAdded          Int      @map("credits_added")
  amountPaidCents       Int      @map("amount_paid_cents")
  createdAt             DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("purchase_records")
}

enum TransactionType {
  DEDUCTION
  REFUND
  INITIAL_GRANT
  PURCHASE
}

model NotifyRequest {
  id        String   @id @default(uuid())
  email     String
  source    String   @default("credits_waitlist")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@map("notify_requests")
}
